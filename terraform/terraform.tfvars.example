# Mini SOC - Terraform variables (Docker)
# Copy to terraform.tfvars and customize if needed

# Wazuh version
wazuh_version = "4.14.5"

# Ports
indexer_port      = 9200
dashboard_port    = 443
manager_agent_port = 1514
manager_authd_port = 1515
manager_api_port  = 55000

# Credentials (change in production!)
indexer_admin_password = "Admin123!"
dashboard_password     = "Admin123!"
api_username           = "wazuh-wui"
api_password           = "MyS3cretPassword"

# Agent
agent_name = "wazuh-agent"
